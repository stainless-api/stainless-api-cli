#!/usr/bin/env bash

set -euo pipefail

ORIGINAL_DIR="$(pwd)"
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/stainless-api/stainless-api-go,github.com/stainless-sdks/stainless-v0-go"

go run ./cmd/stl "$@"
# Build the binary in the project root
cd "$PROJECT_ROOT"
go build -o /tmp/stl-dev ./cmd/stl

# Run it from the original directory
cd "$ORIGINAL_DIR"
/tmp/stl-dev "$@"
